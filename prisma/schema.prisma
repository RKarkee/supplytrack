// Smart Inventory + POS + AI Analytics System
// Database Schema for Individual Shopkeepers in Nepal

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum PaymentMethod {
  CASH
  CARD
  MOBILE_BANKING
  CREDIT
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum ReturnType {
  REFUND
  EXCHANGE
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  OVERDUE_CREDIT
  DEAD_STOCK
  EXPIRY_WARNING
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StockMovementType {
  SALE
  PURCHASE
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT
  OPENING
}

enum SaleTrend {
  INCREASING
  STABLE
  DECREASING
}

// ─── USER / AUTH ────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String
  role           String   @default("owner")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  auditLogs AuditLog[]
  sales     Sale[]
}

// ─── SHOP SETTINGS ─────────────────────────────────────

model ShopSettings {
  id              String   @id @default(cuid())
  shopName        String
  address         String?
  phone           String?
  email           String?
  panNumber       String?  // PAN/VAT number for Nepal
  vatEnabled      Boolean  @default(false)
  vatRate         Decimal  @default(13) @db.Decimal(5, 2)
  currency        String   @default("Rs")
  receiptHeader   String?
  receiptFooter   String?
  defaultCreditLimit Decimal @default(0) @db.Decimal(12, 2)
  safetyStockDays Int      @default(7)
  logoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── CATEGORY ──────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  products Product[]

  @@index([name])
}

// ─── UNIT ──────────────────────────────────────────────

model Unit {
  id           String   @id @default(cuid())
  name         String   @unique  // e.g. "Kilogram", "Piece", "Dozen"
  abbreviation String   @unique  // e.g. "kg", "pc", "dz"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products     Product[]
  productUnits ProductUnit[]
}

// ─── PRODUCT ───────────────────────────────────────────

model Product {
  id             String    @id @default(cuid())
  name           String
  description    String?
  sku            String?   @unique
  barcode        String?   @unique
  categoryId     String
  unitId         String
  purchasePrice  Decimal   @db.Decimal(12, 2)
  sellingPrice   Decimal   @db.Decimal(12, 2)
  mrp            Decimal?  @db.Decimal(12, 2)
  currentStock   Decimal   @default(0) @db.Decimal(12, 3)
  minStock       Decimal   @default(0) @db.Decimal(12, 3)
  maxStock       Decimal?  @db.Decimal(12, 3)
  reorderLevel   Decimal?  @db.Decimal(12, 3)
  imageUrl       String?
  isActive       Boolean   @default(true)
  expiryDate     DateTime?
  supplierLeadDays Int     @default(3)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  category       Category       @relation(fields: [categoryId], references: [id])
  unit           Unit           @relation(fields: [unitId], references: [id])
  productUnits   ProductUnit[]
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]
  returnItems    ReturnItem[]
  forecasts      DemandForecast[]

  @@index([name])
  @@index([barcode])
  @@index([categoryId])
  @@index([sku])
  @@index([categoryId, name])
}

// ─── PRODUCT UNIT (Multi-unit conversion) ──────────────

model ProductUnit {
  id               String  @id @default(cuid())
  productId        String
  unitId           String
  conversionFactor Decimal @db.Decimal(12, 4) // e.g. 1 dozen = 12 pieces
  sellingPrice     Decimal @db.Decimal(12, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  unit    Unit    @relation(fields: [unitId], references: [id])

  @@unique([productId, unitId])
}

// ─── CUSTOMER ──────────────────────────────────────────

model Customer {
  id            String    @id @default(cuid())
  name          String
  phone         String?   @unique
  email         String?
  address       String?
  creditLimit   Decimal   @default(0) @db.Decimal(12, 2)
  creditBalance Decimal   @default(0) @db.Decimal(12, 2) // Outstanding credit
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  sales    Sale[]
  returns  Return[]

  @@index([name])
  @@index([phone])
}

// ─── SUPPLIER ──────────────────────────────────────────

model Supplier {
  id            String    @id @default(cuid())
  name          String
  phone         String?
  email         String?
  address       String?
  contactPerson String?
  panNumber     String?
  leadTimeDays  Int       @default(3)
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  purchaseOrders PurchaseOrder[]

  @@index([name])
}

// ─── SALE ──────────────────────────────────────────────

model Sale {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  customerId      String?
  userId          String
  subtotal        Decimal       @db.Decimal(12, 2)
  discountType    String?       // "percentage" or "flat"
  discountValue   Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  taxableAmount   Decimal       @default(0) @db.Decimal(12, 2)
  vatAmount       Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  creditAmount    Decimal       @default(0) @db.Decimal(12, 2)
  changeAmount    Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus   PaymentStatus @default(PAID)
  notes           String?
  isOfflineSale   Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  customer Customer? @relation(fields: [customerId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  items    SaleItem[]
  payments Payment[]
  returns  Return[]

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([createdAt])
  @@index([paymentStatus])
}

// ─── SALE ITEM ─────────────────────────────────────────

model SaleItem {
  id           String  @id @default(cuid())
  saleId       String
  productId    String
  productName  String  // Snapshot at sale time
  quantity     Decimal @db.Decimal(12, 3)
  unitPrice    Decimal @db.Decimal(12, 2)
  discount     Decimal @default(0) @db.Decimal(12, 2)
  total        Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ─── PAYMENT ───────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  saleId        String
  method        PaymentMethod
  amount        Decimal       @db.Decimal(12, 2)
  reference     String?       // For card/mobile banking reference
  createdAt     DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// ─── PURCHASE ORDER ────────────────────────────────────

model PurchaseOrder {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  supplierId      String
  status          OrderStatus @default(DRAFT)
  subtotal        Decimal     @db.Decimal(12, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  paidAmount      Decimal     @default(0) @db.Decimal(12, 2)
  expectedDate    DateTime?
  receivedDate    DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@index([orderNumber])
  @@index([supplierId])
  @@index([status])
}

// ─── PURCHASE ITEM ─────────────────────────────────────

model PurchaseItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal @db.Decimal(12, 3)
  unitPrice       Decimal @db.Decimal(12, 2)
  total           Decimal @db.Decimal(12, 2)
  receivedQty     Decimal @default(0) @db.Decimal(12, 3)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

// ─── STOCK MOVEMENT ────────────────────────────────────

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 3) // Positive for in, negative for out
  reference   String?           // Sale ID, PO ID, etc.
  notes       String?
  createdAt   DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

// ─── RETURN ────────────────────────────────────────────

model Return {
  id          String     @id @default(cuid())
  returnNumber String    @unique
  saleId      String
  customerId  String?
  type        ReturnType
  totalAmount Decimal    @db.Decimal(12, 2)
  reason      String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  sale     Sale         @relation(fields: [saleId], references: [id])
  customer Customer?    @relation(fields: [customerId], references: [id])
  items    ReturnItem[]

  @@index([saleId])
}

// ─── RETURN ITEM ───────────────────────────────────────

model ReturnItem {
  id        String  @id @default(cuid())
  returnId  String
  productId String
  quantity  Decimal @db.Decimal(12, 3)
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  return  Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([returnId])
}

// ─── EXPENSE ───────────────────────────────────────────

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  expenses Expense[]
}

model Expense {
  id          String   @id @default(cuid())
  categoryId  String
  amount      Decimal  @db.Decimal(12, 2)
  description String
  date        DateTime @default(now())
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([date])
}

// ─── AI ANALYTICS ──────────────────────────────────────

model DemandForecast {
  id                    String    @id @default(cuid())
  productId             String
  forecastMonth         DateTime  // First day of forecast month
  forecastQty           Decimal   @db.Decimal(12, 3)
  trend                 SaleTrend
  trendSlope            Decimal?  @db.Decimal(12, 6)
  reorderLevel          Decimal?  @db.Decimal(12, 3)
  safetyStock           Decimal?  @db.Decimal(12, 3)
  recommendedPurchaseQty Decimal? @db.Decimal(12, 3)
  dailyDemand           Decimal?  @db.Decimal(12, 3)
  marginPercent         Decimal?  @db.Decimal(8, 2)
  isDeadStock           Boolean   @default(false)
  lastSaleDate          DateTime?
  computedAt            DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, forecastMonth])
  @@index([productId])
  @@index([forecastMonth])
  @@index([isDeadStock])
}

// ─── SALES HEATMAP ─────────────────────────────────────

model SalesHeatmap {
  id         String   @id @default(cuid())
  dayOfWeek  Int      // 0=Sunday, 6=Saturday
  hourOfDay  Int      // 0-23
  totalSales Decimal  @db.Decimal(12, 2)
  saleCount  Int
  period     DateTime // First day of the period
  computedAt DateTime @default(now())

  @@unique([dayOfWeek, hourOfDay, period])
  @@index([period])
}

// ─── ALERT ─────────────────────────────────────────────

model Alert {
  id         String        @id @default(cuid())
  type       AlertType
  severity   AlertSeverity
  title      String
  message    String
  productId  String?
  customerId String?
  isRead     Boolean       @default(false)
  isDismissed Boolean      @default(false)
  createdAt  DateTime      @default(now())

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// ─── AUDIT LOG ─────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // CREATE, UPDATE, DELETE, LOGIN, SALE, etc.
  entity    String   // Product, Sale, etc.
  entityId  String?
  details   String?  // JSON string of changes
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}
